# Fraud Hunter — copy to `.env` and fill in. All values are optional:
# missing secrets degrade gracefully (no Mongo -> CSV mode; no Gemini key -> rule-only).

# --- MongoDB (Atlas) -------------------------------------------------------
# Leave MONGO_URI empty to run in CSV-backed in-memory mode (no database).
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=fraudhunter

# --- Gemini ----------------------------------------------------------------
# Leave GEMINI_API_KEY empty to disable AI summaries + the decision-tree tie-breaker.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Analyst notifications -------------------------------------------------
FRAUD_ANALYST_EMAIL=fraud-analyst@example.com
# Transport for escalation alerts: "log" records them without sending (shipped default).
NOTIFY_TRANSPORT=log
